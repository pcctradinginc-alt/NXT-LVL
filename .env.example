# Copy this file to .env and fill in your own secrets for local testing.
# NEVER commit the real .env file (it is git-ignored).

# Gemini API key — get one at https://aistudio.google.com ("Get API key")
GEMINI_API_KEY=

# Tradier API key (brokerage account or sandbox)
TRADIER_API_KEY=

# "prod" (default) or "sandbox" — selects the Tradier base URL
TRADIER_ENV=prod

# Gmail App-Password — Google Account -> Security -> App passwords
GMAIL_APP_PASSWORD=

# Sender / recipient mailbox (usually the same Gmail address)
MAIL_FROM=pcctradinginc@gmail.com
MAIL_TO=pcctradinginc@gmail.com

# Optional: raises GitHub API rate limits for the github_trends collector.
# In GitHub Actions this is provided automatically via ${{ github.token }}.
GITHUB_TOKEN=

# Optional: when set to "1", all collectors short-circuit and return empty
# results immediately (no network calls at all). Used by CI smoke tests.
NXT_OFFLINE=
